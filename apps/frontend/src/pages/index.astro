---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Smart Library IoT Simulation Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <div>
          <p class="eyebrow">IoT Architecture and Protocol</p>
          <h1>Smart Library Noise and Comfort Monitor</h1>
          <p class="subtitle">Simulation-first deployment with virtual sensors, REST, WebSocket, and MQTT-style topics.</p>
        </div>
        <div class="conn" id="connBox">
          <span class="dot" id="connDot"></span>
          <span id="connLabel">Connecting</span>
        </div>
      </header>

      <section class="kpis" id="kpis">
        <article class="kpi"><h2>Avg Noise</h2><p id="kNoise">--</p></article>
        <article class="kpi"><h2>Avg Temperature</h2><p id="kTemp">--</p></article>
        <article class="kpi"><h2>Avg CO2</h2><p id="kCO2">--</p></article>
        <article class="kpi"><h2>Active Alerts</h2><p id="kAlerts">0</p></article>
      </section>

      <section class="grid">
        <article class="panel">
          <div class="panel-head"><h3>Zone Snapshot</h3></div>
          <div id="zones" class="zones"></div>
        </article>

        <article class="panel">
          <div class="panel-head"><h3>Protocol Statistics</h3></div>
          <table class="tbl" id="protocolTable">
            <thead><tr><th>Protocol</th><th>Messages</th><th>Avg Latency</th></tr></thead>
            <tbody></tbody>
          </table>
        </article>

        <article class="panel">
          <div class="panel-head"><h3>Live Alerts</h3></div>
          <div id="alerts" class="stream"></div>
        </article>
      </section>

      <section class="grid two">
        <article class="panel">
          <div class="panel-head"><h3>Telemetry Stream</h3></div>
          <div id="telemetry" class="stream"></div>
        </article>
        <article class="panel">
          <div class="panel-head"><h3>Command Publisher</h3></div>
          <div class="controls">
            <select id="zoneSelect"></select>
            <button data-cmd="silence">Silence Zone</button>
            <button data-cmd="ventilation">Boost Ventilation</button>
            <button data-cmd="ac_cool">Activate Cooling</button>
            <button data-cmd="emergency">Emergency Alert</button>
          </div>
        </article>
      </section>
    </main>
    <script type="module" src="/dashboard.js"></script>
  </body>
</html>
